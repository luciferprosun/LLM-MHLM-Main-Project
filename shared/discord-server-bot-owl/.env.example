# Create a Discord application/bot:
# https://discord.com/developers/applications

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=false
BOT_DISPLAY_NAME=LuciferSun Research Bot
AI_SYSTEM_PROMPT=You are a professional Discord assistant for an open computational research server. Be concise, technically serious, helpful, and skeptical in a scientific way. When uncertain, say what is uncertain. Respond in the same language as the user's message unless explicitly asked otherwise.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODEL=openrouter/free

# Optional: channel ID where scheduled grant alerts should be posted.
DISCORD_ALERT_CHANNEL_ID=

# Comma-separated Discord user IDs allowed to run admin commands.
DISCORD_ADMIN_IDS=

# Search config.
GRANT_KEYWORDS=AI,open source,research software,scientific computing,compute,physics,data infrastructure,reproducibility
GRANT_SCAN_INTERVAL_MINUTES=360
GRANTS_GOV_ROWS=10
