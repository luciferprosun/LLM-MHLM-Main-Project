{"created": "2026-04-29T07:42:13.811846+00:00", "modified": "2026-04-29T07:42:16.057372+00:00", "id": 19878587, "conceptrecid": "19780615", "doi": "10.5281/zenodo.19878587", "conceptdoi": "10.5281/zenodo.19780615", "doi_url": "https://doi.org/10.5281/zenodo.19878587", "metadata": {"title": "LSC 6.2.0: A Phenomenological Framework for Neutrino Propagation and Detector-Frame Tensor Anisotropy", "doi": "10.5281/zenodo.19878587", "publication_date": "2026-04-29", "description": "<p>LSC 6.2.0 is the latest preprint-stage continuation of the public LSC 6.0 phenomenological framework. It introduces a detector-frame tensor anisotropy formulation that separates propagation-level true energy from detector-level reconstructed energy. The draft is prepared for arXiv submission and is currently awaiting category endorsement.</p><p>The model is not presented as confirmed new physics. It is a testable phenomenological ansatz requiring independent review, numerical fitting, and constraints from BEST/GALLEX/SAGE gallium source data, KATRIN beta-spectrum measurements, IceCube anisotropy/systematic studies, and standard three-flavor oscillation data.</p><p>This record is intended to preserve continuity of the LSC research line for grant review and independent verification. The recommended Zenodo strategy is to publish it as a new version of the existing LSC 6.0 conceptual record.</p>", "access_right": "open", "creators": [{"name": "LuciferSun", "affiliation": "Independent Research"}], "keywords": ["neutrino oscillations", "phenomenological model", "detector anisotropy", "tensor response", "gallium anomaly", "KATRIN", "IceCube", "arXiv preprint", "LSC framework"], "related_identifiers": [{"identifier": "10.5281/zenodo.19780616", "relation": "isNewVersionOf", "scheme": "doi"}, {"identifier": "10.5281/zenodo.19843361", "relation": "isSupplementedBy", "scheme": "doi"}, {"identifier": "10.5281/zenodo.19602045", "relation": "isDerivedFrom", "scheme": "doi"}, {"identifier": "https://github.com/luciferprosun/LSC-6.0", "relation": "isSupplementTo", "scheme": "url"}, {"identifier": "https://arxiv.org/auth/endorse?x=7KLAMS", "relation": "isReferencedBy", "scheme": "url"}], "version": "6.2.0-preprint", "language": "eng", "resource_type": {"title": "Preprint", "type": "publication", "subtype": "preprint"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 1, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "19780615"}}]}, "notes": "arXiv submission is prepared but awaiting category endorsement. This Zenodo package is intended as the stable citable preprint record while arXiv endorsement is pending."}, "title": "LSC 6.2.0: A Phenomenological Framework for Neutrino Propagation and Detector-Frame Tensor Anisotropy", "links": {"self": "https://zenodo.org/api/records/19878587", "self_html": "https://zenodo.org/records/19878587", "preview_html": "https://zenodo.org/records/19878587?preview=1", "doi": "https://doi.org/10.5281/zenodo.19878587", "self_doi": "https://doi.org/10.5281/zenodo.19878587", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.19878587", "reserve_doi": "https://zenodo.org/api/records/19878587/draft/pids/doi", "parent": "https://zenodo.org/api/records/19780615", "parent_html": "https://zenodo.org/records/19780615", "parent_doi": "https://doi.org/10.5281/zenodo.19780615", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.19780615", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:19878587/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:19878587/sequence/default", "files": "https://zenodo.org/api/records/19878587/files", "media_files": "https://zenodo.org/api/records/19878587/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:19878587:LSC_6_2_0_social_preview.png/full/%5E10,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:19878587:LSC_6_2_0_social_preview.png/full/%5E50,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:19878587:LSC_6_2